# Required: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Host paths (map to fixed container paths)
WORKSPACE_DIR=./data/workspace
USER_CLAUDE_DIR=./data/user-claude

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_PATH=/twilio/whatsapp
TWILIO_PUBLIC_URL=https://xxxx.ngrok-free.app
TWILIO_VALIDATE_SIGNATURE=false

# Access control — comma-separated phone numbers, empty = allow all
ALLOWED_SENDERS=[]

# Agent limits
MAX_TURNS=30
MAX_BUDGET_USD=1.0
MAX_CONCURRENT_REQUESTS=3
